# FileHost — WhatsApp Media Browser
# Copy to .env and fill in your values

# === Required ===
# WhatsApp chat JID(s) — comma-separated (find via 'wacli chats list')
FILEHOST_WHATSAPP_CHATS=1234567890@g.us

# === Optional ===
# Upload token (leave empty to disable uploads)
FILEHOST_UPLOAD_TOKEN=

# FileHost data directory (default: ./data)
FILEHOST_DIR=./data

# Server
FILEHOST_HOST=127.0.0.1
FILEHOST_PORT=8093
FILEHOST_BASE_URL=http://localhost:8093
FILEHOST_SECRET_KEY=

# File expiry in seconds (default: 86400 = 24h)
FILEHOST_TTL=86400

# === wacli paths (defaults are usually fine) ===
WACLI_BIN=wacli
# WACLI_DB=~/.wacli/wacli.db
# WACLI_STORE=~/.wacli

# === Proxy (for datacenter IPs) ===
# WACLI_PROXY=proxychains4 -q
